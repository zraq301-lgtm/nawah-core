// generator و datasource وجداول المستخدمين تبقى كما هي تماماً دون تغيير...

// 3. جداول المشتريات (تم تعديلها لتطابق حقول واجهة الـ React بدقة)
model Purchase {
  id             String   @id @default(uuid())
  tenant_id      String   @default("default_tenant")
  item           String   // اسم الصنف
  unit           String?  // الوحدة (اختياري)
  quantity       Float    // الكمية
  price          Float    // السعر
  total          Float    // الإجمالي
  supplier       String?  // اسم المورد
  payment_method String   @default("كاش") // طريقة السداد
  purchase_date  String?  // تاريخ الفاتورة
  batch_id       String?  // رقم الشحنة/الـ Batch
  created_at     DateTime @default(now())

  @@map("purchases") // لضمان إنشاء الجدول في Supabase باسم purchases الصغير
}

model OrderRequest {
  id         String   @id @default(uuid())
  tenant_id  String   @default("default_tenant")
  item       String   // الصنف المطلوب
  quantity   Float    // الكمية المطلوبة
  supplier   String   @default("عام") // اسم المورد الموجه له الطلب
  type       String   @default("ERP_ORDER_REQUEST")
  created_at DateTime @default(now())

  @@map("order_requests") // لضمان إنشاء الجدول في Supabase باسم order_requests الصغير
}
