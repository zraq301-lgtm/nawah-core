generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

// 1. جداول المستخدمين والشركات
model Company {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  users     User[]
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  companyId     String?
  company       Company?       @relation(fields: [companyId], references: [id])
  // العلاقات الجديدة: المستخدم يمتلك مشتريات وطلبات خاصة به
  purchases     Purchase[]
  orderRequests OrderRequest[]
}

// 2. جداول المشتريات المعزولة لكل مستخدم
model Purchase {
  id             String   @id @default(uuid())
  tenant_id      String   @default("default_tenant")
  item           String   
  unit           String?  
  quantity       Float    
  price          Float    
  total          Float    
  supplier       String?  
  payment_method String   @default("كاش") 
  purchase_date  String?  
  batch_id       String?  
  created_at     DateTime @default(now())
  
  // حقول العزل والربط مع المستخدم 🛡️
  userId         String
  user           User     @relation(fields: [userId], references: [id])

  @@map("purchases")
}

// 3. جداول الطلبات المعزولة لكل مستخدم
model OrderRequest {
  id         String   @id @default(uuid())
  tenant_id  String   @default("default_tenant")
  item       String   
  quantity   Float    
  supplier   String   @default("عام") 
  type       String   @default("ERP_ORDER_REQUEST")
  created_at DateTime @default(now())
  
  // حقول العزل والربط مع المستخدم 🛡️
  userId     String
  user       User     @relation(fields: [userId], references: [id])

  @@map("order_requests")
}
